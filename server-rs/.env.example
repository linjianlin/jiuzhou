# server-rs 基础运行配置
SERVICE_NAME="九州修仙录 Rust Backend"
NODE_ENV=development
JWT_SECRET="jiuzhou-xiuxian-secret-key"
JWT_EXPIRES_IN="7d"
HOST=0.0.0.0
PORT=6011
CORS_ORIGIN="http://localhost:6010"
LOG_LEVEL=info
WANDER_AI_ENABLED=false
CAPTCHA_PROVIDER=local
TENCENT_CAPTCHA_APP_ID=0
TENCENT_CAPTCHA_APP_SECRET_KEY=""
TENCENT_CAPTCHA_SECRET_ID=""
TENCENT_CAPTCHA_SECRET_KEY=""
GAME_TIME_SCALE=60
MARKET_PHONE_BINDING_ENABLED=false
ALIYUN_ACCESS_KEY_ID=""
ALIYUN_ACCESS_KEY_SECRET=""
ALIYUN_SMS_SIGN_NAME=""
ALIYUN_SMS_VERIFY_TEMPLATE_CODE=""
MARKET_PHONE_BINDING_CODE_EXPIRE_SECONDS=300
MARKET_PHONE_BINDING_SEND_COOLDOWN_SECONDS=60
MARKET_PHONE_BINDING_SEND_HOURLY_LIMIT=5
MARKET_PHONE_BINDING_SEND_DAILY_LIMIT=10

# 当前阶段保持沿用现有 PostgreSQL / Redis 依赖
DATABASE_URL="postgresql://postgres:your-db-password@localhost:5432/jiuzhou"
REDIS_URL="redis://localhost:6379"

# 本地上传目录默认复用现有 Node 服务目录；生产环境可改为挂载卷路径
UPLOADS_DIR="../server/uploads"

# 腾讯云 COS（未完整配置时自动回退本地上传）
COS_SECRET_ID=""
COS_SECRET_KEY=""
COS_BUCKET=""
COS_REGION=""
COS_AVATAR_PREFIX="avatars/"
COS_GENERATED_IMAGE_PREFIX="jiuzhou/generated/"
COS_DOMAIN=""
COS_STS_DURATION_SECONDS=600

# 对外 HTTP client 超时（毫秒）
HTTP_CLIENT_TIMEOUT_MS=15000

# 爱发电 OpenAPI / 重试
AFDIAN_OPEN_API_BASE_URL="https://ifdian.net"
AFDIAN_OPEN_USER_ID=""
AFDIAN_OPEN_TOKEN=""
AFDIAN_MESSAGE_RETRY_ENABLED=true
AFDIAN_MESSAGE_RETRY_INTERVAL_SECONDS=60
AFDIAN_MESSAGE_RETRY_BATCH_SIZE=10

# AI 文本模型（OpenAI-compatible）
AI_TECHNIQUE_MODEL_PROVIDER=""
AI_TECHNIQUE_MODEL_URL=""
AI_TECHNIQUE_MODEL_KEY=""
AI_TECHNIQUE_MODEL_NAME=""

AI_PARTNER_MODEL_PROVIDER=""
AI_PARTNER_MODEL_URL=""
AI_PARTNER_MODEL_KEY=""
AI_PARTNER_MODEL_NAME=""

AI_WANDER_MODEL_PROVIDER=""
AI_WANDER_MODEL_URL=""
AI_WANDER_MODEL_KEY=""
AI_WANDER_MODEL_NAME=""
