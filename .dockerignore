# Dependencies
node_modules
**/node_modules

# Build outputs (will be built in container)
**/dist
**/dist-ssr
server-rs/target

# Git
.git
.gitignore

# Documentation
*.md
docs/

# Logs
*.log
docker-build.log

# Environment files (sensitive)
**/.env
**/.env.*
!**/.env.example

# IDE and tools
.vscode
.idea
.kiro
.claude

# OS files
.DS_Store
Thumbs.db

# Test and coverage
coverage/
.nyc_output/
**/*.test.*
**/*.spec.*

# 服务端构建上下文冗余文件（脚本 / 本地环境 / Python）
# 说明：当前服务端镜像使用仓库根目录作为构建上下文，需要在根 .dockerignore 中忽略。
server/src/scripts/
server/generated/
server/.cache/
server/.venv*/
server/uploads/
server/**/__pycache__/
server/**/*.pyc
server/**/*requirements*.txt

# Misc
*.bak
*.tmp
*.temp
