{
  "name": "jiuzhou",
  "version": "1.0.0",
  "private": true,
  "description": "九州修仙录",
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "dev": "sh -c 'pnpm dev:client & pnpm dev:server'",
    "dev:client": "pnpm --filter ./client dev",
    "dev:server": "cargo run --manifest-path server-rs/Cargo.toml --bin server-rs",
    "migrate:server": "cargo run --manifest-path server-rs/Cargo.toml --bin migrate",
    "dev:server:node": "pnpm --filter ./server dev",
    "build": "sh -c 'pnpm build:client && pnpm build:server'",
    "build:client": "pnpm --filter ./client build",
    "build:client:no-image": "pnpm --filter ./client build:no-image",
    "build:server": "cargo build --manifest-path server-rs/Cargo.toml --release",
    "build:server:node": "pnpm --filter ./server build",
    "test:local:server": "cargo test --manifest-path server-rs/Cargo.toml",
    "test:local:server:node": "pnpm --filter ./server test:local",
    "test:local:technique-generation": "pnpm --filter ./server test:local:technique-generation",
    "test:model:technique": "pnpm --filter ./server test:model:technique",
    "docker:build": "./docker-build.sh",
    "docker:push": "./docker-build.sh",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down"
  },
  "type": "module",
  "pnpm": {
    "onlyBuiltDependencies": [
      "prisma",
      "esbuild",
      "@prisma/engines",
      "sharp"
    ]
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  }
}
